# Copy to .env and fill in values. Do not commit .env.

# Public frontend URL (trip invites, member-added links, redirects after email actions).
# Must match the URL users use in the browser.
APP_URL=http://localhost:5173
# Browser-reachable API base URL (no path). Used for the verify-email link in messages; must match where the API is served.
APP_PUBLIC_API_URL=http://localhost:8080

# Database (required for local run)
DB_PASSWORD=postgres
# Local mvn test uses surf_spots_test (see pom.xml). In Docker, /.dockerenv activates jdbc:postgres:5432/postgres.

# Must match SESSION_SECRET in surf-spots frontend so the API can verify signed session cookies (e.g. surf sessions list).
SESSION_SECRET=

# Email (optional; production uses Scaleway SMTP from application.yml)
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENABLED=false
# Optional verified sender for Scaleway / SMTP (e.g. noreply@yourdomain.com)
MAIL_FROM=
# Inbox for contact form (defaults to hello@surfspots.com if unset)
MAIL_CONTACT_TO=

# Mapbox (used for static map images in session notification emails)
# Use the same token as VITE_MAP_ACCESS_TOKEN in the frontend .env
MAPBOX_ACCESS_TOKEN=

# Scaleway Object Storage (for media upload; leave empty to disable)
# Use SCW_* for credentials and region/endpoint, and S3_BUCKET for bucket name.
SCW_ACCESS_KEY=
SCW_SECRET_KEY=
S3_BUCKET=surf-spots-media-dev
SCW_ENDPOINT=https://s3.fr-par.scw.cloud
SCW_REGION=fr-par
# Optional helper for scripts/set-bucket-cors.ps1 (comma-separated list)
CORS_ALLOWED_ORIGINS=http://localhost:5173
