# Copy to .env and fill in values. Do not commit .env.

APP_URL=http://localhost:5173

# Database (required for local run)
DB_PASSWORD=postgres
# Local mvn test uses surf_spots_test (see pom.xml). In Docker, /.dockerenv activates jdbc:postgres:5432/postgres.

# Must match SESSION_SECRET in surf-spots frontend so the API can verify signed session cookies (e.g. surf sessions list).
SESSION_SECRET=

# Email (optional)
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENABLED=false

# Scaleway Object Storage (for media upload; leave empty to disable)
# Use SCW_* for credentials and region/endpoint, and S3_BUCKET for bucket name.
SCW_ACCESS_KEY=
SCW_SECRET_KEY=
S3_BUCKET=surf-spots-media-dev
SCW_ENDPOINT=https://s3.fr-par.scw.cloud
SCW_REGION=fr-par
# Optional helper for scripts/set-bucket-cors.ps1 (comma-separated list)
CORS_ALLOWED_ORIGINS=http://localhost:5173
